{
  "name": "hito-kyori-memo-mvp",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --host lan --port 8080",
    "web": "expo start --web --host lan --port 8080",
    "android": "expo start --android --host lan --port 8080",
    "ios": "expo start --ios --host lan --port 8080",
    "build:web": "expo export --platform web --output-dir dist",
    "build:web:github-pages": "npm run build:web && node scripts/prepare-github-pages.js",
    "doctor": "expo-doctor"
  },
  "dependencies": {
    "expo": "~51.0.28",
    "expo-sqlite": "~14.0.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-web": "~0.19.12",
    "@expo/metro-runtime": "~3.2.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "expo-doctor": "^1.6.1"
  }
}
